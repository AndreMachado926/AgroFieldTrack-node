<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <title>Admin Remédios</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background-color: #000;
            color: #fff;
            min-height: 100vh;
        }

        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            background-color: #111;
            display: flex;
            padding: 10px 20px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.5);
            z-index: 1000;
        }

        .navbar a {
            color: #fff;
            text-decoration: none;
            margin-right: 20px;
            font-weight: bold;
        }

        .navbar a:hover {
            color: #4A9782;
        }

        .container {
            width: 90%;
            max-width: 1200px;
            margin: 80px auto 50px auto;
        }

        h1 {
            text-align: center;
            margin-bottom: 20px;
        }

        .add-btn {
            background-color: #4A9782;
            color: #fff;
            padding: 10px 20px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            margin-bottom: 20px;
            font-size: 16px;
        }

        .add-btn:hover {
            background-color: #36735b;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            padding: 12px 15px;
            border-bottom: 1px solid #444;
        }

        th {
            background-color: #222;
        }

        tr:hover {
            background-color: #333;
        }

        .action-btn {
            background-color: #dc3545;
            color: #fff;
            border: none;
            padding: 6px 12px;
            border-radius: 4px;
            cursor: pointer;
            margin-right: 5px;
        }

        .edit-btn {
            background-color: #007bff;
        }

        .modal {
            display: none;
            position: fixed;
            z-index: 2000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.8);
        }

        .modal-content {
            background-color: #111;
            margin: 8% auto;
            padding: 20px;
            border-radius: 10px;
            width: 500px;
            box-shadow: 0 0 10px #4A9782;
        }

        .modal-content input,
        .modal-content select,
        .modal-content textarea {
            width: 100%;
            padding: 10px;
            margin: 8px 0;
            border-radius: 5px;
            border: none;
            background-color: #222;
            color: #fff;
        }

        .close-btn {
            float: right;
            cursor: pointer;
            font-size: 20px;
            color: #dc3545;
        }
    </style>
</head>

<body>

<div class="navbar">
    <a href="/admin/users">Usuários</a>
    <a href="/admin/animais">Animais</a>
    <a href="/admin/plantacoes">Plantações</a>
    <a href="/admin/remedios">Remédios</a>
</div>

<div class="container">
    <h1>Admin Remédios</h1>

    <button class="add-btn" onclick="openAddModal()">Adicionar Remédio</button>

    <table>
        <thead>
            <tr>
                <th>Nome</th>
                <th>Animal</th>
                <th>Data</th>
                <th>Observações</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            <% remedios.forEach(remedio => { %>
                <tr>
                    <td><%= remedio.nome %></td>
                    <td>
                        <% if(remedio.animal_id){ %>
                            <%= remedio.animal_id.nome %> (<%= remedio.animal_id._id %>)
                        <% } else { %>
                            -
                        <% } %>
                    </td>
                    <td><%= remedio.data.toISOString().substring(0,10) %></td>
                    <td><%= remedio.observacoes || '-' %></td>
                    <td>
                        <button class="action-btn edit-btn"
                            onclick='openEditModal(<%= JSON.stringify(remedio) %>)'>
                            Editar
                        </button>

                        <button class="action-btn"
                            onclick="deleteRemedio('<%= remedio._id %>')">
                            Deletar
                        </button>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<!-- MODAL -->
<div id="remedioModal" class="modal">
    <div class="modal-content">
        <span class="close-btn" onclick="closeModal()">×</span>
        <h2 id="modalTitle">Adicionar Remédio</h2>

        <form id="remedioForm">
            <input type="hidden" name="id" id="remedioId">

            <input type="text" name="nome" placeholder="Nome do remédio" required>

            <select name="animal_id" id="animalSelect" required>
                <option value="">Selecione o Animal</option>
                <% animais.forEach(animal => { %>
                    <option value="<%= animal._id %>">
                        <%= animal.nome %> (<%= animal._id %>)
                    </option>
                <% }) %>
            </select>

            <input type="date" name="data" required>

            <textarea name="observacoes" placeholder="Observações"></textarea>

            <button type="submit" class="add-btn">Adicionar</button>
        </form>
    </div>
</div>

<script>
    const modal = document.getElementById("remedioModal");
    const form = document.getElementById("remedioForm");
    const modalTitle = document.getElementById("modalTitle");

    function openAddModal() {
        modal.style.display = "block";
        form.reset();
        document.getElementById("remedioId").value = "";
        modalTitle.textContent = "Adicionar Remédio";
        form.querySelector("button").textContent = "Adicionar";
    }

    function openEditModal(remedio) {
        modal.style.display = "block";

        document.getElementById("remedioId").value = remedio._id;
        form.nome.value = remedio.nome || '';
        form.animal_id.value = remedio.animal_id?._id || remedio.animal_id || '';
        form.data.value = remedio.data.substring(0,10);
        form.observacoes.value = remedio.observacoes || '';

        modalTitle.textContent = "Editar Remédio";
        form.querySelector("button").textContent = "Salvar Alterações";
    }

    function closeModal() {
        modal.style.display = "none";
        form.reset();
    }

    window.onclick = function(e) {
        if (e.target === modal) closeModal();
    }

    form.addEventListener("submit", function(e) {
        e.preventDefault();

        const data = Object.fromEntries(new FormData(form).entries());

        let url = "/admin/remedios/add";
        if (data.id) url = "/admin/remedios/edit";

        fetch(url, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data)
        })
        .then(res => res.json())
        .then(result => {
            if (result.success) {
                alert(data.id ? "Remédio editado!" : "Remédio adicionado!");
                window.location.reload();
            } else {
                alert("Erro: " + result.message);
            }
        });
    });

    function deleteRemedio(id) {
        if (confirm("Tem certeza que deseja deletar este remédio?")) {
            fetch(`/admin/remedios/delete/${id}`, { method: "DELETE" })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    alert("Remédio deletado!");
                    window.location.reload();
                } else {
                    alert("Erro: " + data.message);
                }
            });
        }
    }
</script>

</body>
</html>